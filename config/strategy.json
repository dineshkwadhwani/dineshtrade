{
  "version": "2.0",
  "_comment": "Schema 2.0 — multi-strategy framework. The top-level `capital` and `strategies` are the new source of truth. The remaining keys (capital_legacy, limits, targets, strategy2_momentum, ema, strategy1_reactive, sources) are kept for backwards-compatibility with existing consumers in Phase 1; they will be removed in Phase 3 once all callers migrate to lib/strategyConfig.ts.",

  "capital": {
    "source": "live",
    "perTrade": 5000,
    "maxBuysPerDay": 3,
    "maxSellsPerDay": 3,
    "circuitBreakerPct": -5,
    "intradayCircuitTripPct": 0,
    "intradayCircuitResumePct": 0,
    "panicDropPct": 0,
    "panicWindowMin": 0,
    "maxDeployPct": 80,
    "sharedPool": true,
    "maxPositions": 10,
    "maxBuysPerSymbol": 3,
    "minDropBetweenBuysPct": 10
  },

  "strategies": [
    {
      "id": "accumulator",
      "name": "Accumulator",
      "type": "dip",
      "active": true,
      "color": "#52b788",
      "scanIntervalMin": 30,
      "watchlist": ["listA"],
      "params": {
        "emaPeriod": 20,
        "entryBelowPct": 5,
        "strongBuyBelowPct": 8,
        "minDownDays": 3,
        "capitulationFloorPct": 12,
        "tranche2AboveEMAPct": 3.0,
        "reactiveDrop": 3.0,
        "reactiveIntervalMin": 30,
        "firesOnAnyMode": true,
        "maxPerSector": 3
      },
      "exits": {
        "t1Pct": 5.0,
        "t2Pct": 8.0
      },
      "giftNiftyGate": {
        "enabled": true,
        "minPct": null,
        "maxPct": -0.5
      }
    },
    {
      "id": "catalyst",
      "name": "Catalyst (Momentum)",
      "type": "momentum",
      "active": true,
      "color": "#c9a84c",
      "scanIntervalMin": 5,
      "watchlist": ["listA"],
      "params": {
        "minDayGainPct": 0.5,
        "maxDayGainPct": 1.5,
        "consecutiveCandles": 3,
        "emaProximityPct": 3.0,
        "volumeAvgDays": 10,
        "scanStartHHMM": "09:30",
        "scanEndHHMM": "14:30",
        "deliveryHandoffDays": 15,
        "exitSameDayTime": "15:10",
        "exitSameDayOnPositive": false,
        "squareOffEOD": false
      },
      "exits": {
        "t1Pct": 1.5,
        "t2Pct": 2.0
      },
      "giftNiftyGate": {
        "enabled": false,
        "minPct": null,
        "maxPct": null
      }
    },
    {
      "id": "market_boom",
      "name": "Market Boom",
      "type": "momentum",
      "active": false,
      "color": "#60a5fa",
      "scanIntervalMin": 5,
      "watchlist": ["listA", "listB"],
      "params": {
        "minDayGainPct": 1.5,
        "maxDayGainPct": 3.0,
        "consecutiveCandles": 2,
        "emaProximityPct": 5.0,
        "volumeAvgDays": 5,
        "scanStartHHMM": "09:30",
        "scanEndHHMM": "14:30",
        "deliveryHandoffDays": 0,
        "exitSameDayTime": "15:10",
        "exitSameDayOnPositive": true,
        "squareOffEOD": true
      },
      "exits": {
        "t1Pct": 2.0,
        "t2Pct": 3.0
      },
      "giftNiftyGate": {
        "enabled": true,
        "minPct": 1.0,
        "maxPct": null
      }
    }
  ],

  "capital_legacy": {
    "total": 50000,
    "perTrade": 5000,
    "maxPositions": 10
  },
  "limits": {
    "maxBuysPerDay": 3,
    "maxSellsPerDay": 3,
    "circuitBreakerPct": -5
  },
  "targets": {
    "intraday_t1_pct": 1.5,
    "intraday_t2_pct": 2.0,
    "delivery_ema_pct": 4.0,
    "strategy1_tranche2_above_ema_pct": 3.0
  },
  "strategy2_momentum": {
    "minDayGainPct": 0.5,
    "maxDayGainPct": 1.5,
    "emaProximityPct": 3.0,
    "consecutiveCandles": 3,
    "scanStartHHMM": "09:30",
    "scanEndHHMM": "14:30",
    "volumeAvgDays": 10
  },
  "ema": {
    "period": 20,
    "entryBelowPct": 5,
    "strongBuyBelowPct": 8,
    "minDownDays": 3
  },
  "strategy1_reactive": {
    "dropPct": 3.0,
    "scanStartHHMM": "09:15",
    "scanEndHHMM": "14:00",
    "intervalMin": 30,
    "firesOnAnyMode": true
  },
  "sources": {
    "brokerRecommendations": [
      { "name": "ICICI Direct",    "url": "https://www.icicidirect.com/research/equity/stock-picks" },
      { "name": "HDFC Securities", "url": "https://www.hdfcsec.com/research/equity-research" },
      { "name": "Moneycontrol",    "url": "https://www.moneycontrol.com/stocks/marketstats/recos/" },
      { "name": "Motilal Oswal",   "url": "https://www.motilaloswal.com/markets/equity" }
    ]
  }
